# ── Advisor (same free Groq model on Mac + Render) ───────────────────────────
# Get a free key: https://console.groq.com (no credit card)
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Offline fallback — used when GROQ_API_KEY is empty (local dev only)
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_NUM_PREDICT=1536
# OLLAMA_KEEP_ALIVE=30m

# ── Paid providers (optional — switch LLM_PROVIDER / EMBEDDING_PROVIDER) ────────
# ANTHROPIC_API_KEY=sk-ant-...
# VOYAGE_API_KEY=pa-...

# ── Supabase (auth + optional hosted Postgres) ─────────────────────────────────
# Create a project at https://supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # backend-only; not used by app yet
# SUPABASE_JWT_SECRET=only-for-legacy-HS256-projects
# New projects use ES256 — backend verifies via JWKS at SUPABASE_URL/auth/v1/.well-known/jwks.json
REQUIRE_AUTH=true

# ── Database ───────────────────────────────────────────────────────────────────
# Set USE_SUPABASE_DB=true + SUPABASE_DB_PASSWORD to store ALL data in Supabase Postgres
USE_SUPABASE_DB=false
# From: https://supabase.com/dashboard/project/<your-project-ref>/settings/database
SUPABASE_DB_PASSWORD=

# Local Docker (when USE_SUPABASE_DB=false):
DATABASE_URL=postgresql://finsight:finsight@localhost:5432/finsight

# Or full Supabase URL (auto-built from password when USE_SUPABASE_DB=true):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# When Supabase is unreachable (campus Wi-Fi), backend auto-falls back to local Docker Postgres:
DATABASE_FALLBACK_URL=postgresql://finsight:finsight@localhost:5432/finsight
DATABASE_FALLBACK_ENABLED=true
ENVIRONMENT=development

# Optional API key — when set, backend requires X-API-Key header (except /health)
# FINSIGHT_API_KEY=your-secret-key

# Chat rate limit — requests per minute per IP/user (0 = disabled)
CHAT_RATE_LIMIT_PER_MINUTE=30

# ── Production / Railway deploy ────────────────────────────────────────────────
# ENVIRONMENT=production
# CORS_ORIGINS=https://your-frontend.up.railway.app
# FINNHUB_API_KEY=your-finnhub-key
# TAVILY_API_KEY=tvly-...   # optional — better web search for agent
# WEB_SEARCH_ENABLED=true

# Plaid — compliant live bank linking (sandbox free at https://dashboard.plaid.com)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_TOKEN_ENCRYPTION_KEY=  # Fernet key — generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PLAID_SYNC_INTERVAL_SECONDS=3600
# PLAID_WEBHOOK_SECRET=

# Invite-only beta (comma-separated emails; empty = open)
# BETA_ALLOWED_EMAILS=you@example.com,friend@example.com

# Weekly email digest (optional — required for digest delivery)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=FinSight <noreply@yourdomain.com>

# LOG_LEVEL=INFO
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_KEY=your-secret-key
