# ── Free local setup (default — no API keys required) ─────────────────────────
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Paid providers (optional — switch LLM_PROVIDER / EMBEDDING_PROVIDER) ────────
# ANTHROPIC_API_KEY=sk-ant-...
# VOYAGE_API_KEY=pa-...

# Database (localhost when running outside Docker; use @db:5432 inside Docker)
DATABASE_URL=postgresql://finsight:finsight@localhost:5432/finsight

# pgvector collection name
PGVECTOR_COLLECTION=transaction_embeddings

# App environment: development | production
ENVIRONMENT=development

# Optional API key — when set, backend requires X-API-Key header (except /health)
# FINSIGHT_API_KEY=your-secret-key

# Frontend (Next.js public vars)
NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_KEY=your-secret-key

# ── Supabase (auth + hosted Postgres) ─────────────────────────────────────────
# Create a project at https://supabase.com → Settings → API
# SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-backend-only
# SUPABASE_JWT_SECRET=only-for-legacy-HS256-projects
# New Supabase projects use ES256 — backend verifies via JWKS at SUPABASE_URL/auth/v1/.well-known/jwks.json
# REQUIRE_AUTH=true
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
