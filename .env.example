# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embeddings — https://www.voyageai.com)
VOYAGE_API_KEY=pa-...

# Database (override for local dev without Docker)
DATABASE_URL=postgresql://finsight:finsight@localhost:5432/finsight

# pgvector collection name
PGVECTOR_COLLECTION=transaction_embeddings

# App environment: development | production
ENVIRONMENT=development

# Frontend (Next.js public vars)
NEXT_PUBLIC_API_URL=http://localhost:8000
